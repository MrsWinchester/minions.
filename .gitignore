# ── Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
build/
dist/

# ── Django
db.sqlite3
*.sqlite3
media/
staticfiles/
*.log

# ── Environments (never commit your venv)
.venv/
venv/
env/
ENV/
pip-wheel-metadata/

# ── Secrets/config (never commit real secrets)
.env
*.env
.env.*.local

# ── IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Node (if present)
node_modules/

# ── Sphinx
# Ignore everything in docs/build, but allow the HTML output
docs/build/*
!docs/build/html/
!docs/build/html/**/*
